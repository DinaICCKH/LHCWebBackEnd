@using DMSWebPortal.Models;
@{
    ViewBag.Title = "Sale Employee Detail";
    SaleEmployeeMasterDataResult sales = ViewBag.sales ?? new SaleEmployeeMasterDataResult();
    List<ItemMasterDataResult> items = ViewBag.items ?? new List<ItemMasterDataResult>();
    List<ICC_Get_BP_Master_Data> bps = ViewBag.bps ?? new List<ICC_Get_BP_Master_Data>();
}
<div class="hidden-feild" style="display:none;">
    <input type="hidden" id="txt-docentry" value="" />
</div>
<div class="row row-sub-page">
    <div class="container-fluid container-sub-page">
        <div class="row row-sub-page-header">
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-name">
                <h6>Sale Employee Detail</h6>
            </div>
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-path">
                <h6>SAP / Sale Employee Detail</h6>
            </div>
        </div>
        <div class="row row-sub-page-body">
            <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 filter-container">
                <div class="form-control input-container flex-row">
                    <label for="textbox" class="width-30">Sale Code: </label>
                    <input type="text" id="textbox" class="styled-input width-70 txt-sale-code" placeholder="Sale Code" value="@sales.SalesCode" readonly />
                </div>
                <div class="form-control input-container flex-row">
                    <label for="textbox" class="width-30">Warehouse: </label>
                    <input type="text" id="textbox" class="styled-input width-70 txt-sale-whs-name" placeholder="Warehuose" value="@sales.WhsName" readonly />
                </div>
            </div>
            <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 col-container-tab">
                <div class="container-fluid container-emp-tab">
                    <div class="row row-btn-tab">
                        <div class="col col-xxl-3 col-xl-3 col-lg-1 col-md-12 col-sm-12 col-12 col-btn-emp-tab">
                            <div class="btn-emp-tab btn-emp-tab-customer" data-btn-tab="customer">Customer</div>
                            <div class="btn-emp-tab btn-emp-tab-item" data-btn-tab="item">Item</div>
                        </div>
                    </div>
                    <div class="row row-box-tab">
                        <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 box-tab box-tab-customer">
                            <div class="table-container">
                                <table class="styled-table table-bp">
                                    <thead>
                                        <tr>
                                            <th>No</th>
                                            <th width="10%">Card Code</th>
                                            <th>Card Name</th>
                                            <th>Foreign Name</th>
                                            <th>Group</th>
                                            <th>Currency</th>
                                            <th>Address</th>
                                            <th>Phone</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            foreach (var x in bps)
                                            {
                                                <tr>
                                                    <td>@x.RowNumber</td>
                                                    <td>@x.CardCode</td>
                                                    <td>@x.CardName</td>
                                                    <td>@(x.CardFName ?? "NON")</td>
                                                    <td>@x.GroupName</td>
                                                    <td></td>
                                                    <td></td>
                                                    <td>@x.Phone1</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 box-tab box-tab-item">

                            <div class="table-container">
                                <table class="styled-table table-item">
                                    <thead>
                                        <tr>
                                            <th>No</th>
                                            <th>Item Code</th>
                                            <th>Item Name</th>
                                            <th>Item Group</th>
                                            <th>OnHand</th>
                                            <th>Inventory UoM</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            foreach (var x in items)
                                            {
                                                <tr>
                                                    <td>@x.RowNumber</td>
                                                    <td>@x.ItemCode</td>
                                                    <td>@x.ItemName</td>
                                                    <td>@x.ItemGroupName</td>
                                                    <td>@(x.Onhand?.ToString("N2"))</td>
                                                    <td>@(x.InvUoMCode)</td>
                                                    <td>
                                                        <div class="badge bg-@(x.Status == "Active" ? "success" : "danger")" role="alert">
                                                            @(x.Status ?? "NON")
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="col col-xxl-2 col-xl-2 col-lg-12 col-md-12 col-sm-12 col-12 my-4 col-sub-page-body">
                <div class="button-container flex-row">
                    @*<button class="btn-save" id="btn-save-plan"><i class="fa-solid fa-save"></i>&nbsp;Save</button>*@
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        hideLoading();
        DefaultEmpTab();
    });
</script>

