
@{
    ViewBag.Title = "Edit Sale Order";
    SO head = ViewBag.head ?? new SO();
    List<SaleEmployeeMasterDataResult> sales = ViewBag.sales ?? new List<SaleEmployeeMasterDataResult>();
    List<tblPrinciple> principles = ViewBag.principle ?? new List<tblPrinciple>();
    var username = ViewBag.username;
}
<div class="hidden-feild" style="display:none;">
    <input type="hidden" id="txt-docentry" value="@head.DocEntry" />
    <input type="hidden" class="styled-input width-60 def_pricelist" />
</div>
<div class="row row-sub-page">
    <div class="container-fluid container-sub-page">
        
        <div class="row row-sub-page-header">
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-name">
                @if (ViewBag.salestype=="van"){
                    <h6>Invoice Detail</h6>
                }
                else{
                    <h6>Edit Sale Order</h6>
                }
            </div>
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-path">
                @if (ViewBag.salestype == "van")
                {
                    <h6>Sale Order / Invoice Detail</h6>
                }
                else
                {
                    <h6>Sale Order / Edit Sale Order</h6>
                }
            </div>
        </div>
        <div class="row row-sub-page-body">
            <div class="col col-xxl-4 col-xl-4 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Customer: </label>
                    <input type="text" id="textbox" class="styled-input width-60 txt-cardcode" placeholder="CardCode" value="" readonly />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Name: </label>
                    <input type="text" id="textbox" class="styled-input width-60 txt-cardname" placeholder="CardName" value="" readonly />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Contact Person: </label>
                    <select id="combobox" class="combobox width-60 txt-contact-person">
                    </select>
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Address: </label>
                    <input type="text" id="textbox" class="styled-input width-60 txt-address" placeholder="Customer Address" value="" readonly />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Tax Type: </label>
                    <select id="combobox" class="combobox width-60 combobox-taxtype">
                        @if ((head.VATType?.ToLower() ?? "") == "tax")
                        {
                            <option value="TAX" selected>Tax</option>
                            <option value="NON">Non Tax</option>
                        }
                        else if ((head.VATType?.ToLower() ?? "") == "none" || (head.VATType?.ToLower() ?? "") == "non")
                        {
                            <option value="TAX">Tax</option>
                            <option value="NON" selected>Non Tax</option>
                        }
                        else
                        {
                            <option value="TAX">Tax</option>
                            <option value="NON">Non Tax</option>
                        }
                    </select>
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-40">Sale Employee: </label>
                    <select id="combobox" class="combobox width-60 combobox-sale-emp">
                        <option value=""></option>
                        @foreach (var x in sales)
                        {
                            if (x.SalesCode == head.SalesCode)
                            {
                                <option value="@x.SalesCode" selected data-whs="@x.Whs" data-code="@x.SalesCode" data-sales-type="@x.SALType">@x.SalesName</option>
                            }
                            else
                            {
                                <option value="@x.SalesCode" data-whs="@x.Whs" data-code="@x.SalesCode" data-sales-type="@x.SALType">@x.SalesName</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col col-xxl-4 col-xl-4 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
            </div>
            <div class="col col-xxl-4 col-xl-4 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
                <div class="input-container flex-row">
                    <label for="textbox" class="width-50">Document No: </label>
                    <input type="text" id="textbox" class="styled-input width-50 txt-doc-num" placeholder="Ducument Number" value="" readonly />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-50">Posting Date: </label>
                    <input type="text" id="textbox" class="styled-input width-50 txt-doc-date" placeholder="dd-mm-yyyy" readonly disabled />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-50">Delivery Date: </label>
                    <input type="text" id="textbox" class="styled-input width-50 txt-delivery-date" placeholder="dd-mm-yyyy" readonly disabled />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-50">Document Date: </label>
                    <input type="text" id="textbox" class="styled-input width-50 txt-tax-date" placeholder="dd-mm-yyyy" readonly />
                </div>
                <div class="input-container flex-row">
                    <label for="textbox" class="width-50">SAP No: </label>
                    <input type="text" id="textbox" class="styled-input width-50 txt-sap-no"  readonly />
                </div>
            </div>
            <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 p-0">
                <div class="table-container table-so-container">
                    <table class="table-so">
                        <thead>
                            <tr>
                                <th width="5%">No</th>
                                <th width="8%">Item Code</th>
                                <th>Item Name</th>
                                <th width="7%">UOM Code</th>
                                <th width="11%">Warehouse</th>
                                <th width="7%">InStock</th>
                                <th width="7%">Quantity</th>
                                <th width="7%">Unit Price</th>
                                <th width="7%">Dis %</th>
                                <th width="7%">Dis.Amt</th>
                                <th width="7%">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @*<tr>
                            <td><input type="text" class="td-input" value="1" readonly></td>
                            <td><input type="text" class="td-input" value="I001" readonly /></td>
                            <td><input type="text" class="td-input" value="Cambodia Beer" /></td>
                            <td>
                                <select class="td-input">
                                    <option value="Unit">Unit</option>
                                    <option value="Can">Can</option>
                                </select>
                            </td>
                            <td><input type="text" class="td-input td-input-right" value="5.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="2.50" /></td>
                            <td><input type="text" class="td-input td-input-right" value="0.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="12.50" /></td>
                        </tr>
                        <tr>
                            <td><input type="text" class="td-input" value="2" readonly></td>
                            <td><input type="text" class="td-input" value="I001" readonly /></td>
                            <td><input type="text" class="td-input" value="Cambodia Beer" /></td>
                            <td>
                                <select class="td-input">
                                    <option value="Unit">Unit</option>
                                    <option value="Can">Can</option>
                                </select>
                            </td>
                            <td><input type="text" class="td-input td-input-right" value="5.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="2.50" /></td>
                            <td><input type="text" class="td-input td-input-right" value="0.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="12.50" /></td>
                        </tr>
                        <tr>
                            <td><input type="text" class="td-input" value="3" readonly></td>
                            <td><input type="text" class="td-input" value="I001" readonly /></td>
                            <td><input type="text" class="td-input" value="Cambodia Beer" /></td>
                            <td>
                                <select class="td-input">
                                    <option value="Unit">Unit</option>
                                    <option value="Can">Can</option>
                                </select>
                            </td>
                            <td><input type="text" class="td-input td-input-right" value="5.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="2.50" /></td>
                            <td><input type="text" class="td-input td-input-right" value="0.00" /></td>
                            <td><input type="text" class="td-input td-input-right" value="12.50" /></td>
                        </tr>*@
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><input type="text" class="td-input" value="1" readonly disabled></td>
                                <td class="btn-show-item"><input type="text" class="td-input" value="" placeholder="Item Code" readonly /></td>
                                <td class="btn-show-item"><input type="text" class="td-input" value="" placeholder="Item Name" readonly /></td>
                                <td>
                                    <select class="td-input" disabled>
                                    </select>
                                </td>
                                <td>
                                    <select class="td-input" disabled>
                                    </select>
                                </td>
                                <td><input type="text" class="td-input td-input-right" value="0.00" disabled /></td>
                                <td><input type="text" class="td-input td-input-right" value="1" disabled /></td>
                                <td><input type="text" class="td-input td-input-right" value="0.00" disabled /></td>
                                <td><input type="text" class="td-input td-input-right" value="0.00" disabled /></td>
                                <td><input type="text" class="td-input td-input-right" value="0.00" disabled /></td>
                                <td><input type="text" class="td-input td-input-right" value="0.00" disabled /></td>
                            </tr>
                            <tr>
                                <td rowspan="7" valign="top"><input type="text" class="td-input" value="Remark" readonly disabled /></td>
                                <td rowspan="7" colspan="7" valign="top"><textarea id="textbox" class="td-textarea txt-remark" placeholder="Remark"></textarea></td>
                                <td colspan="2"><input type="text" class="td-input td-input-right" value="Sub Total Before Discount" readonly /></td>
                                <td><input type="text" class="td-input td-input-right txt-sub-total-before" value="0.00" /></td>
                            </tr>
                            <tr>
                                <td colspan="2"><input type="text" class="td-input td-input-right txt-doc-dis-per-label" value="Discount(%)" readonly /></td>
                                <td>
                                    <input type="text" class="td-input td-input-right txt-doc-discount" value="0.00" style="display:none" />
                                    <input type="text" class="td-input td-input-right txt-doc-discount-amount" value="0.00" readonly />
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2"><input type="text" class="td-input td-input-right" value="Sub Total After Discount" readonly /></td>
                                <td><input type="text" class="td-input td-input-right txt-sub-total-after" value="0.00" /></td>
                            </tr>
                            <tr>
                                <td colspan="2"><input type="text" class="td-input td-input-right" value="VAT Amount" readonly /></td>
                                <td><input type="text" class="td-input td-input-right txt-vat-amount" value="0.00" /></td>
                            </tr>
                            <tr>
                                <td colspan="2"><input type="text" class="td-input td-input-right" value="Total" readonly /></td>
                                <td><input type="text" class="td-input td-input-right txt-doc-total" value="0.00" /></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            @if(head.DocStatus=="Draft"){

                @if (username?.ToLower() == "fn01" || username?.ToLower() == "fn02" || username?.ToLower() == "pro")
                {
                    @* if (head.CardCode == "GN00001") *@
                    <div class="col col-xxl-24 col-xl-5 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
                        <div class="flex-row gap-2">
                            <button class="btn btn-primary btn-reject" id="btn-update-so"><i class="fa-solid fa-rotate"></i>&nbsp;Update</button>
                            @* <button class="btn btn-primary btn-warning" id="btn-so_run_promotion"><i class="fa-solid fa-save"></i>&nbsp;Run Promotion</button> *@
                            <button class="btn btn-success" id="btn-approved"><i class="fa-solid fa-check"></i>&nbsp;Approve</button>
                            <button class="btn btn-danger" id="btn-reject"><i class="fa-solid fa-xmark"></i>&nbsp;Reject</button>
                        </div>
                    </div>
                }
                @* @if (head.CreatedBy.ToLower() == username.ToLower())
                {
                    <div class="col col-xxl-2 col-xl-2 col-lg-12 col-md-12 col-sm-12 col-12 my-4 col-sub-page-body">
                        <div class="button-container flex-row">
                            <button class="btn btn-primary btn-warning" id="btn-cancel"><i class="fa-solid fa-xmark"></i>&nbsp;Cancel</button>
                        </div>
                    </div>
                } *@
            }
            @if (username?.ToLower() == "manager"){
                <div class="col col-xxl-24 col-xl-5 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
                    <div class="flex-row">
                        <button class="btn btn-primary" id="btn-manager-update"><i class="fa-solid fa-rotate"></i>&nbsp;Update</button>
                        @* <button class="btn btn-primary btn-warning" id="btn-so_run_promotion"><i class="fa-solid fa-save"></i>&nbsp;Run Promotion</button> *@
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Customer List Modal -->
<div class="modal fade" id="customerListModal" tabindex="-1" aria-labelledby="customerListLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="customerListLabel">Customer List</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="filter-container">
                    <div class="form-group w-100">
                        <input type="text" class="styled-input txt-so-search-bp" placeholder="Typing code or name to search here" />
                    </div>
                </div>
                <div class="table-container">
                    <table class="table table-striped table-hover styled-table table-so-customer">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th width="10%">Code</th>
                                <th>Name</th>
                                <th>Foreign Name</th>
                                <th>Address</th>
                                <th width="10%">Phone</th>
                                <th>Tax ID</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- dynamic rows go here -->
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="col-12 mt-3">
                    <div class="pagination">
                        <!-- dynamic pagination -->
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="btn-choose-customer">Choose</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>

<!-- Item List Modal -->
<div class="modal fade" id="itemListModal" tabindex="-1" aria-labelledby="itemListLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="itemListLabel">Item List</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="filter-container">
                    <div class="form-group w-25">
                        <select class="styled-input txt-principle">
                            @foreach (var x in principles)
                            {
                                <option value="@x.Code">@x.Dscription</option>
                            }
                        </select>
                    </div>
                    <div class="form-group w-75">
                        <input type="text" class="styled-input txt-so-search-item" placeholder="Typing code or name to search here" />
                    </div>
                </div>
                <div class="table-container">
                    <table class="table table-striped table-hover styled-table table-so-item">
                        <thead>
                            <tr>
                                <th width="5%">No</th>
                                <th width="10%">Code</th>
                                <th>Name</th>
                                <th>Group</th>
                                <th>Promotion</th>
                                <th width="15%">Principle</th>
                                <th>Select</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Dynamic rows go here -->
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="col-12 mt-3">
                    <div class="pagination">
                        <!-- dynamic pagination -->
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="btn-choose-item">Choose</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>

        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        flatpickr(".datetime", {
            dateFormat: "d-m-Y",
        });
        GetSODetail(@head.DocEntry);
         $(".txt-so-search-bp").keyup(function(){
            getSOCustomerList(1);
        });
        $(".txt-so-search-bp").keydown(function(){
            getSOCustomerList(1);
        });
        $(".txt-so-search-item").keyup(function(){
            getSOItemList(1);
        });
        $(".txt-so-search-item").keydown(function(){
            getSOItemList(1);
        });
        $(".txt-principle").change(function(){
            getSOItemList(1);
        });
    });
</script>

