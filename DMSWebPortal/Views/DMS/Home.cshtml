@{
    ViewBag.Title = "Home";
    // Safely get counts from ViewBag
    int itemcount = ViewBag.itemcount != null ? (int)ViewBag.itemcount : 0;
    int bpcount = ViewBag.bpcount != null ? (int)ViewBag.bpcount : 0;
    int salecount = ViewBag.salecount != null ? (int)ViewBag.salecount : 0;
    int visitcount = ViewBag.visitcount != null ? (int)ViewBag.visitcount : 0;
    int socount = ViewBag.socount != null ? (int)ViewBag.socount : 0;
    int promotioncount = ViewBag.promotioncount != null ? (int)ViewBag.promotioncount : 0;
    int reasoncount = ViewBag.reasoncount != null ? (int)ViewBag.reasoncount : 0;
    int usercount = ViewBag.user != null ? (int)ViewBag.user : 0;
}

<style>
    .container-box {
        display: block;
        background: white; /* One single background color */
        --border-radius: 12px;
        transition: all 0.3s ease;
        padding: 20px 15px;
        text-align: center;
        height: 100%;
        text-decoration: none;
        border: 1px solid blue; /* subtle border for definition */
        --background-color:var(--theme-color);
        
    }

        .container-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12);
        }

    .content-box i {
        font-size: 2.5rem;
        margin-bottom: 12px;
    }

    .content-box h6 {
        font-size: 1rem;
        color: #444;
        margin-bottom: 10px;
        font-weight: 600;
        line-height: 1.3;
    }

    .content-box .count {
        font-size: 2rem;
        font-weight: bold;
        margin: 0;
        line-height: 1;
    }

    /* Different icon colors only (background stays white) */
    .icon-item {
        color: #1e88e5;
    }
    /* blue */
    .icon-bp {
        color: #22c55e;
    }
    /* green */
    .icon-sale {
        color: #f97316;
    }
    /* orange */
    .icon-visit {
        color: #9333ea;
    }
    /* purple */
    .icon-so {
        color: #0891b2;
    }
    /* cyan */
    .icon-promo {
        color: #eab308;
    }
    /* yellow */
    .icon-reason {
        color: #ec4899;
    }
    /* pink */
    .icon-user {
        color: #4b5563;
    }
    /* gray */
</style>

<div class="row row-sub-page">
    <div class="container-fluid container-sub-page">
        <div class="row row-sub-page-header">
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-6 col-6 col-page-name">
                <h6>Home</h6>
            </div>
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-6 col-6 col-page-path">
                <h6>DMS / Home</h6>
            </div>
        </div>
        <div class="row row-sub-page-body">
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="ItemMasterData">
                    <div class="content-box">
                        <i class="fas fa-boxes-stacked icon-item"></i>
                        <h6>SAP Item Master Data</h6>
                        <p class="count text-primary">@itemcount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="BPMasterData">
                    <div class="content-box">
                        <i class="fas fa-users icon-bp"></i>
                        <h6>SAP Customer Master Data</h6>
                        <p class="count text-success">@bpcount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="SaleEmployee">
                    <div class="content-box">
                        <i class="fas fa-user-tie icon-sale"></i>
                        <h6>SAP Sale Employee</h6>
                        <p class="count text-warning">@salecount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="PlanTracking">
                    <div class="content-box">
                        <i class="fas fa-map-location-dot icon-visit"></i>
                        <h6>Visit Plan</h6>
                        <p class="count text-purple">@visitcount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="SOList">
                    <div class="content-box">
                        <i class="fas fa-file-invoice-dollar icon-so"></i>
                        <h6>DMS Sale Order</h6>
                        <p class="count text-info">@socount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="PromotionList">
                    <div class="content-box">
                        <i class="fas fa-gift icon-promo"></i>
                        <h6>Promotion</h6>
                        <p class="count text-warning">@promotioncount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="ReasonList">
                    <div class="content-box">
                        <i class="fas fa-circle-exclamation icon-reason"></i>
                        <h6>Reason</h6>
                        <p class="count text-danger">@reasoncount</p>
                    </div>
                </a>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 col-box-item">
                <a class="container-box" asp-controller="DMS" asp-action="UserList">
                    <div class="content-box">
                        <i class="fas fa-user-cog icon-user"></i>
                        <h6>User</h6>
                        <p class="count text-muted">@usercount</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        //GetHome();
    });
</script>