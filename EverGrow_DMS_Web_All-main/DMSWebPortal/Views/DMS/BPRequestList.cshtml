@{
    ViewBag.Title = "BP Request List";
    var salesList = ViewBag.saleslist as List<DMSWebPortal.Models.tblSalesEmployee>??new List<tblSalesEmployee>();
}
<div class="row row-sub-page">
    <div class="container-fluid container-sub-page">
        <div class="row row-sub-page-header">
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-name">
                <h6>BP Request List</h6>
            </div>
            <div class="col col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 col-page-path">
                <h6>BP Request / BP Request List</h6>
            </div>
        </div>
        <div class="row row-sub-page-body">
            <div class="col col-xxl-8 col-xl-8 col-lg-12 col-md-12 col-sm-12 col-12 filter-container">
                <div class="form-control combobox-container">
                    <label for="combobox">Status: *</label>
                    <select id="combobox" class="combobox txt-status">
                        <option value="" disabled>---select one---</option>
                        <option value="All">All</option>
                        <option value="Draft" selected>Draft</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
                <div class="form-control combobox-container">
                    <label for="combobox">Search by: *</label>
                    <select id="combobox" class="combobox txt-search-by">
                        <option value="" disabled>---select one---</option>
                        <option value="All" selected>All</option>
                        <option value="CardName">Name</option>
                        <option value="CardFName">Foreign Name</option>
                        <option value="SalesName">Sales Name</option>
                        <option value="Phone">Phone</option>
                        <option value="Address">Address</option>
                    </select>
                </div>
                <div class="form-control input-container" id="dv_salesman">
                    <label for="textbox">Search: *</label>
                    <input type="text" id="textbox" class="styled-input width-100 txt-search" placeholder="Typing here..." />
                </div>
                <div class="form-control input-container" id="dv_salesman" style="display:none">
                    <label for="textbox">Select Salesman: </label>
                    <select id="combobox_salesman" class="combobox">
                        <option value="All">All</option>
                        @foreach (var x in salesList)
                        {
                            <option value="@x.U_SalesCode">@x.SalesName</option>
                        }
                    </select>
                </div>
                <div class="form-control combobox-container">
                    <label for="combobox">Show Per Page: *</label>
                    <select id="combobox" class="combobox txt-limit">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="500">500</option>
                    </select>
                </div>
            </div>
            <div class="col col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12 col-sub-page-body">
                <div class="table-container">
                    <table class="styled-table table-bordered table table-bp-request-list">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>App Code</th>
                                <th>Name</th>
                                <th>Foreign Name</th>
                                <th>Address</th>
                                <th>Sales Name</th>
                                <th>Phone</th>
                                <th>Request Date</th>
                                <th>Status</th>
                                <th>SAP No</th>
                                <th>Error</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="col-12 mt-3">
                    <div class="pagination">
                        <!-- dynamic pagination -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        GetBPRequestList(1);
        $(".txt-limit").change(function () {
            GetBPRequestList(1);
        });
        $(".txt-search").keyup(function () {
            GetBPRequestList(1);
        });
        $(".txt-search").keydown(function () {
            GetBPRequestList(1);
        });
        $(".txt-from-date").change(function () {
            GetBPRequestList(1);
        });
        $(".txt-to-date").change(function () {
            GetBPRequestList(1);
        });
        $(".txt-status").change(function () {
            GetBPRequestList(1);
        });
        $(".txt-search-by").change(function () {
            if($(".txt-search-by").val()=="Salesman"){
                $("#dv_general").hide();
                $("#dv_salesman").show();
            }
            else{
                $("#dv_general").show();
                $("#dv_salesman").hide();
            }
            GetBPRequestList(1);
        });
        $("#combobox_salesman").change(function () {
            GetBPRequestList(1);
        });
    });
</script>

