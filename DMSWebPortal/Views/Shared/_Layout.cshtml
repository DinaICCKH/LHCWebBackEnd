@{
    var baseUrl = UrlHelper.GetBaseUrl(Context);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DMSWebPortal</title>
    @* block link *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link href="~/css/style.css" rel="stylesheet" />
	<link href="~/lib/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/DMSWebPortal.styles.css" asp-append-version="true" />
	<link href="~/lib/flatpicker/flatpicker.min.css" rel="stylesheet" />
    @* block script *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script src="~/js/jwtservice.js"></script>
    <script src="~/js/dms.js" asp-append-version="true"></script>
    <script src="~/lib/flatpicker/flatpicker.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
    @* for alert *@
	<link href="~/lib/alertify/alertify.min.css" rel="stylesheet" />
	<link href="~/lib/alertify/themes/default.min.css" rel="stylesheet" />
    @* <link href="~/lib/alertify/themes/bootstrap.min.css" rel="stylesheet" /> *@
	<script src="~/lib/alertify/alertify.min.js"></script>
</head>
<body>
    
    <div class="container-fluid top-container-bar">
        <div class="row row-header row-block-menu">
            <div class="col col-xxl-2 col-xl-2 col-lg-push-0 col-md-12 col-sm-12 col-12 col-block-menu">
                <a class="system-name" asp-controller="DMS" asp-action="Home" >DMS Admin</a>
            </div>
            <div class="col col-xxl-7 col-xl-7 col-lg-8 col-md-12 col-sm-12 col-12 col-block-menu">
                <ul class="ul-main-menu">
                    <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>Master Data</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="ItemMasterData">Item&nbsp;Master&nbsp;Data</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="BPMasterData">Customer&nbsp;Master&nbsp;Data</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="SaleEmployee">Sales&nbsp;Employee&nbsp;List</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="ReasonList">Reason&nbsp;List</a></li>
                        </ul>
                    </li>
                    <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>Visit&nbsp;Plan</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="NewVisitPlan">New&nbsp;Visit&nbsp;Plan</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="PlanTracking">Plan&nbsp;List</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="ImportVisitPlan">Import&nbsp;Visit&nbsp;Plan</a></li>
                        </ul>
                    </li>
                    <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>Sales&nbsp;Order</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="NewSaleOrder">Sale&nbsp;Order</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="SOList">Sale&nbsp;Order&nbsp;List</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="InvList">Invoice&nbsp;List</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="NonOrder">None&nbsp;Order&nbsp;List</a></li>
                        </ul>
                    </li>
                    @* Remove Promotion menu - comment out:
                    <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>Promotion</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="PromotionSetup">Promotion&nbsp;Setup</a></li>
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="PromotionList">Promotion&nbsp;List</a></li>
                        </ul>
                    </li>
                    *@

                    <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>BP&nbsp;Request</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="BPRequestList">BP&nbsp;Request&nbsp;List</a></li>
                        </ul>
                    </li>

                    @* <li class="li-main-menu">
                        <a class="btn-main-menu" href="#"><span>Reports</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" href="/Reports/rptvisitplan">Visit Plan</a></li>
                        </ul>
                    </li> *@

                    <li class="li-main-menu" id="li_admin">
                        <a class="btn-main-menu" href="#"><span>Administrator</span><span><i class="fa-solid fa-caret-down"></i></span></a>
                        <ul class="ul-sub-menu">
                            <li><a class="sub-menu" asp-controller="DMS" asp-action="UserList">User&nbsp;List</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
            <div class="col col-xxl-3 col-xl-3 col-lg-4 col-md-12 col-sm-12 col-12 col-block-menu col-block-profile">
                <div class="notification-box">
                    <div class="btn-notfication" title="Noification">
                        <span class="f-18"><i class="fa-solid fa-bell"></i></span>
                        <span class="pop-notification-num">0</span>
                    </div>
                </div>
                <div class="company-box" style="display:none">
                    <div class="btn-company" title="Company">
                        <span><i class="fa-solid fa-building"></i></span>
                        <span class="company-name">LMM</span>
                    </div>
                </div>
                <div class="profile-box">
                    <div class="btn-profile" title="User Account" role="button">
                        <span class="user-name">
                            Admin
                        </span>
                        <span class="box-image"><img class="user-image" src="https://e7.pngegg.com/pngimages/348/800/png-clipart-man-wearing-blue-shirt-illustration-computer-icons-avatar-user-login-avatar-blue-child.png" /></span>
                    </div>
                </div>
                <!-- 🔽 Notification dropdown -->
                <div id="notificationList" class="notification-dropdown" style="display:none;">
                    <div class="notification-header">
                        <strong>Notifications</strong>
                        <button id="clearAll" class="btn btn-primary clear-all">Clear All</button>
                    </div>
                    <div class="notification-content">
                        <!-- JS will insert notifications here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid body-content">
        @RenderBody()
    </div>
    <div class="loading" style="width: 100%; background-color: #00000078 !important; height: 100%; position: fixed; z-index: 100; left: 0; top: 0;display:flex;justify-content:center;align-items:center;">
        <div class="img-box-loading" style="width:300px;height:180px;border-radius:10px;">
            <img src="~/assets/loading.gif" style="width: 100%; height: 100%; object-fit: cover; border-radius: 10px;" />
        </div>
    </div>
    <div class="container-alert" style="width: 100%; background-color: #00000078 !important; height: 100%; position: fixed; z-index: 10000000000000; left: 0; top: 0;display:flex;justify-content:center;align-items:center;display:none;">
        <div class="alert-content" style="width:450px;border-radius:5px;background-color:white;padding:10px;">
            <div class="box-title" style="min-height: 100px; height: auto;">
                <p style="font-size:14px;" class="alert-text">Object Reference not set instance object. Could not find store proceedure.</p>
            </div>
            <div class="box-button">
                <div class="btn btn-success btn-close-alert" onclick="CloseAlert()" style="min-width:100px;font-size:14px;border-radius:5px;display:none">Ok</div>
                <div class="btn btn-success btn-reload-alert" onclick="ReloadAlert()" style="min-width: 100px; font-size: 14px; border-radius: 5px;display:none ">Ok</div>
            </div>
            <div class="box-btn-sign-out" style="display:none;">
                <div class="btn btn-danger btn-sign-out" onclick="Logout()" style="min-width:100px;font-size:14px;border-radius:5px;">Signout</div>
                <div class="btn btn-warning btn-close-alert" onclick="CloseAlert()" style="min-width: 100px; font-size: 14px; border-radius: 5px;">Cancel</div>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3"></div>

    <div class="pop-hover-list">
        <table class="table-pop-list">
            <thead>
                <tr><td colspan="3">List of Customer</td></tr>
                <tr>
                    <th>No</th>
                    <th>Code</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>C001</td>
                    <td>Meas Rotanak</td>
                </tr>
                <tr>
                    <td>1</td>
                    <td>C001</td>
                    <td>Meas Rotanak</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="border-top text-muted">
        <div class="container p-2">
            &copy; @DateTime.Now.Year - DMSWebPortal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        baseUrl = '@baseUrl';
        $(document).ready(function () {
            UserData = JSON.parse(localStorage.getItem("UserData"));
            if (UserData === null) {
                GoLoginPage();
            }
            SetDefaultAfterLogin();
            SetUserPermission();
        });
    </script>
</body>
</html>
